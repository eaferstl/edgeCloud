    "@libp2p/circuit-relay-v2": "4.2.6",
    "@libp2p/gossipsub": "16.0.1",
    "@libp2p/identify": "4.1.7",
    "@libp2p/tcp": "11.0.21",
    "@libp2p/websockets": "10.1.14",
    "@multiformats/multiaddr": "13.0.3",
    "@orbitdb/core": "4.0.0",
    "better-sqlite3": "12.10.0",
    "blockstore-level": "4.0.1",
    "datastore-level": "13.0.1",
    "express": "5.2.1",
    "helia": "6.1.4",
    "libp2p": "3.3.3",
