  "version": "0.1.0",
  "description": "edgeCloud rendezvous/central server: libp2p relay + OrbitDB peer + HTTP bridge + key registry",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
