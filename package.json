{
  "name": "edgecloud",
  "private": true,
  "version": "0.1.0",
  "description": "edgeCloud — decentralized compute demo on OrbitDB + Helia + js-libp2p",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "worker",
    "agent_mcp_integration/mcp"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "e2e:local": "node scripts/e2e-local.mjs",
    "server": "npm run start --workspace @edgecloud/server",
    "worker": "npm run start --workspace @edgecloud/worker",
    "agent-mcp": "npm run start --workspace @edgecloud/agent-mcp",
    "check:device-registry": "node --check device_registry/index.js"
  }
}
